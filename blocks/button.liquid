
{% liquid
  assign block_settings = block.settings
  assign button_icon = block_settings.icon | default: 'none'
  assign icon_position = block_settings.icon_position | default: 'after'
  assign button_height = block_settings.button_height | default: 48
%}

{% render 'button-custom-styles', block_settings: block_settings, block_id: block.id %}

<a
  {% if block_settings.link == blank %}
    role="link"
    aria-disabled="true"
  {% else %}
    href="{{ block_settings.link }}"
  {% endif %}
  class="
    button-block
    button-block--icon-{{ icon_position }}
    size-style
    {{ block_settings.style_class }}
    {{ block_settings.style_class }}--{{ block.id }}
  "
  style="{% render 'size-style', settings: block_settings %} --button-block-min-height: {{ button_height }}px;"
  {% if block_settings.open_in_new_tab %}
    target="_blank"
    rel="noopener noreferrer"
  {% endif %}
  {{ block.shopify_attributes }}
>
  {% if button_icon != 'none' %}
    <span class="button-block__icon">
      <svg
        aria-hidden="true"
        focusable="false"
        viewBox="0 0 20 20"
      >
        {% render 'icon', icon: button_icon %}
      </svg>
    </span>
  {% endif %}
  <span class="button-block__label">{{ block_settings.label }}</span>
</a>

{% stylesheet %}
  .button-block.button-block {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--gap-sm);
    min-height: var(--button-block-min-height, 48px);
  }

  .button-block--icon-after .button-block__icon {
    order: 2;
  }

  .button-block__icon {
    display: inline-flex;
    flex: 0 0 auto;
    width: var(--icon-size-sm);
    height: var(--icon-size-sm);
  }

  .button-block__icon svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.button",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "t:settings.label",
      "default": "t:text_defaults.button_label"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:settings.link"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "t:settings.open_new_tab",
      "default": false
    },
    {
      "type": "select",
      "id": "icon",
      "label": "t:settings.icon",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "arrow",
          "label": "t:options.arrow"
        },
        {
          "value": "heart",
          "label": "t:options.heart"
        },
        {
          "value": "leaf",
          "label": "t:options.leaf"
        },
        {
          "value": "lock",
          "label": "t:options.lock"
        },
        {
          "value": "map_pin",
          "label": "t:options.map_pin"
        },
        {
          "value": "price_tag",
          "label": "t:options.price_tag"
        },
        {
          "value": "return",
          "label": "t:options.return"
        },
        {
          "value": "star",
          "label": "t:options.star"
        },
        {
          "value": "truck",
          "label": "t:options.truck"
        }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "icon_position",
      "label": "t:settings.position",
      "options": [
        {
          "value": "before",
          "label": "Before"
        },
        {
          "value": "after",
          "label": "After"
        }
      ],
      "default": "after",
      "visible_if": "{{ block.settings.icon != 'none' }}"
    },
    {
      "type": "select",
      "id": "style_class",
      "label": "t:settings.style",
      "options": [
        {
          "value": "button",
          "label": "t:options.primary"
        },
        {
          "value": "button-secondary",
          "label": "t:options.secondary"
        },
        {
          "value": "button-unstyled",
          "label": "t:options.link"
        },
        {
          "value": "button-custom",
          "label": "t:options.custom"
        }
      ],
      "default": "button",
      "info": "t:info.edit_button_style_in_theme_settings"
    },
    {
      "type": "header",
      "content": "t:content.button_colors",
      "visible_if": "{{ block.settings.style_class == \"button-custom\" }}"
    },
    {
      "type": "color",
      "id": "custom_button_background",
      "label": "t:settings.background",
      "default": "{{ settings.color_palette.foreground }}",
      "alpha": true,
      "visible_if": "{{ block.settings.style_class == 'button-custom' }}"
    },
    {
      "type": "color",
      "id": "custom_button_text",
      "label": "t:settings.text",
      "default": "{{ settings.color_palette.background }}",
      "alpha": true,
      "visible_if": "{{ block.settings.style_class == 'button-custom' }}"
    },
    {
      "type": "color",
      "id": "custom_button_border",
      "label": "t:settings.borders",
      "default": "{{ settings.color_palette.background }}",
      "alpha": true,
      "visible_if": "{{ block.settings.style_class == 'button-custom' }}"
    },
    {
      "type": "color",
      "id": "link_text_color",
      "label": "t:settings.link_text_color",
      "placeholder": "t:settings.default",
      "visible_if": "{{ block.settings.style_class == 'button-unstyled' }}"
    },
    {
      "type": "header",
      "content": "t:content.size"
    },
    {
      "type": "range",
      "id": "button_height",
      "label": "t:settings.height",
      "min": 36,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "select",
      "id": "width",
      "label": "t:settings.width_desktop",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit_content"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "fit-content"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "t:settings.custom_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width == \"custom\" }}"
    },
    {
      "type": "select",
      "id": "width_mobile",
      "label": "t:settings.width_mobile",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit_content"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "fit-content"
    },
    {
      "type": "range",
      "id": "custom_width_mobile",
      "label": "t:settings.custom_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width_mobile == \"custom\" }}"
    }
  ],
  "presets": [
    {
      "name": "t:names.button",
      "category": "t:categories.basic",
      "settings": {
        "link": "shopify://collections/all"
      }
    }
  ]
}
{% endschema %}
