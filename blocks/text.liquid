
{% liquid
  assign block_settings = block.settings
  assign legacy_text = block_settings.text

  assign heading_desktop = block_settings.heading_desktop
  assign heading_mobile = block_settings.heading_mobile | default: heading_desktop
  assign text_desktop = block_settings.text_desktop | default: legacy_text
  assign text_mobile = block_settings.text_mobile | default: text_desktop

  assign text_width = block_settings.width

  if block_settings.font_size contains 'heading-lg' or block_settings.font_size contains 'heading-xl'
    assign type = 'display'
  elsif block_settings.font_size contains 'heading'
    assign type = 'heading'
  else
    assign type = 'body'
  endif

  if block_settings.type_preset == 'rte' or block_settings.type_preset == 'paragraph'
    assign is_rte = true
  endif

  assign heading_element = 'div'
  if block_settings.type_preset == 'h1'
    assign heading_element = 'h1'
  elsif block_settings.type_preset == 'h2'
    assign heading_element = 'h2'
  elsif block_settings.type_preset == 'h3'
    assign heading_element = 'h3'
  elsif block_settings.type_preset == 'h4'
    assign heading_element = 'h4'
  elsif block_settings.type_preset == 'h5'
    assign heading_element = 'h5'
  elsif block_settings.type_preset == 'h6'
    assign heading_element = 'h6'
  endif

  capture text_block_classes
    if text_width == '100%'
      echo 'text-block--align-' | append: block_settings.alignment
      if block_settings.max_width == 'none'
        echo ' text-block--full-width '
      endif
    endif
    if block_settings.type_preset == 'custom'
      echo ' custom-typography '
      if block_settings.font_size != ''
        echo ' custom-font-size '
      endif
      if block_settings.color != ''
        echo ' custom-color '
      endif
    endif
    if block_settings.background
      echo ' text-block--background '
    endif
    if is_rte
      echo ' rte '
    endif
  endcapture

  capture attributes
    echo 'class="spacing-style text-block text-block--' | append: block.id | append: ' '
    echo block_settings.type_preset | append: ' ' | append: text_block_classes | append: '" '

    echo 'style="'
    render 'spacing-padding', settings: block_settings
    render 'typography-style', settings: block_settings
    if block_settings.text_color != blank
      echo '--color: ' | append: block_settings.text_color | append: ';'
      echo '--color-rgb: ' | append: block_settings.text_color.rgb | append: ';'
    endif
    echo '--width: ' | append: text_width | append: ';'
    echo '--max-width: var(--max-width--' | append: type | append: '-' | append: block_settings.max_width | append: ');'
    if text_width == '100%'
      echo '--text-align: ' | append: block_settings.alignment | append: ';'
    endif
    if block_settings.background
      assign text_background_color = block_settings.background_color | default: 'rgb(255 255 255 / 1.0)'
      echo '--text-background-color: ' | append: text_background_color | append: ';'
      echo '--text-corner-radius: ' | append: block_settings.corner_radius | append: 'px;'
      echo '--text-padding: max(var(--padding-2xs), calc((var(--text-corner-radius) + var(--padding-xs)) * (1 - cos(45deg))));'
    endif
    echo '" '
    echo block.shopify_attributes
  endcapture

  assign element = 'div'
  if is_rte
    assign element = 'rte-formatter'
  endif
%}

{% if heading_desktop != blank or text_desktop != blank or heading_mobile != blank or text_mobile != blank %}
  <{{ element }} {{ attributes | strip_newlines | strip }}>
    <div class="hidden--mobile">
      {% if heading_desktop != blank %}
        <{{ heading_element }}>{{ heading_desktop }}</{{ heading_element }}>
      {% endif %}
      {% if text_desktop != blank %}
        {{ text_desktop }}
      {% endif %}
    </div>
    <div class="desktop:hidden">
      {% if heading_mobile != blank %}
        <{{ heading_element }}>{{ heading_mobile }}</{{ heading_element }}>
      {% endif %}
      {% if text_mobile != blank %}
        {{ text_mobile }}
      {% endif %}
    </div>
  </{{ element }}>
{% endif %}

